{
  "template_name": "boardgame",
  "engine": "phaser",
  "phaser_version": "3.90.0",
  "physics": "none",
  "aspect_ratio": "16:9",
  "target_fps": 60,
  "scenes": ["BootScene", "PreloadScene", "MenuScene", "GameScene", "PauseScene", "GameOverScene", "WinScene"],
  "features": {
    "player": {
      "movement": [],
      "input": "mouse_touch_only",
      "sprite_type": "procedural_shapes"
    },
    "turn_system": {
      "type": "sequential",
      "max_players": 4,
      "default_players": 2,
      "ai_opponents": true,
      "ai_strategies": ["random", "greedy"]
    },
    "board": {
      "type": "grid",
      "configurable_size": true,
      "default_rows": 8,
      "default_cols": 8,
      "cell_size": 48,
      "features": ["piece_placement", "selection", "capture", "hover_highlight"]
    },
    "scoring": {
      "per_player": true,
      "win_conditions": ["score_threshold", "board_full", "no_valid_moves"],
      "resources": ["score"]
    },
    "ui": {
      "hud": ["current_player", "scores", "turn_number"],
      "menus": ["main_menu", "pause", "game_over", "win", "mode_select"]
    },
    "audio": {
      "sfx": ["place", "select", "invalid", "capture", "turn", "win", "game_over"],
      "music": ["menu_theme", "game_theme"]
    },
    "effects": {
      "visual": ["hover_highlight", "float_text", "piece_animation"]
    }
  },
  "test_hooks": {
    "expose_on_window": true,
    "api": {
      "getPlayer": "returns {currentPlayer, name, isAI, scores}",
      "getScore": "returns player 1 score",
      "getLives": "returns turn number",
      "getEnemies": "returns [] (not applicable)",
      "getCurrentScene": "returns scene key string",
      "getLevel": "returns current level number",
      "getBoard": "returns 2D board state array",
      "getTurn": "returns current turn number",
      "getScores": "returns all player scores array",
      "simulateClick": "places piece at row,col for testing"
    }
  },
  "kenney_assets": {
    "tileset": "pixel-platformer/Tilemap/tilemap_packed.png",
    "characters": "pixel-platformer/Tilemap/tilemap-characters_packed.png",
    "tile_width": 18,
    "tile_height": 18
  },
  "deployment": {
    "bundle_type": "folder",
    "build_tool": "vite",
    "output": "dist/",
    "files": ["index.html", "game.js", "assets/"]
  }
}
