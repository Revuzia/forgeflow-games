{
  "template_name": "3d-arpg",
  "engine": "threejs",
  "threejs_version": "0.172.0",
  "physics": "cannon-es",
  "view": "isometric",
  "aspect_ratio": "16:9",
  "target_fps": 60,
  "features": {
    "camera": {
      "type": "isometric_follow",
      "angle_pitch": 45,
      "angle_yaw": 45,
      "distance": 15,
      "smooth_follow": true
    },
    "player": {
      "movement": ["click_to_move", "wasd", "attack_melee", "attack_ranged", "dodge", "use_potion"],
      "controls": {
        "move": "WASD or click ground",
        "attack": "Click enemy or X key",
        "dodge": "Space",
        "potions": "1 = health, 2 = mana",
        "inventory": "I key"
      },
      "stats": ["health", "mana", "attack", "defense", "speed", "xp", "level"]
    },
    "enemies": {
      "types": ["melee_patrol", "melee_chase", "ranged", "tank", "boss"],
      "ai": "state_machine",
      "loot_drops": true
    },
    "dungeon": {
      "generation": "procedural_rooms",
      "features": ["rooms", "corridors", "doors", "torches", "traps", "stairs_down"]
    },
    "combat": {
      "type": "real_time",
      "hit_detection": "distance_check",
      "damage_numbers": true,
      "screen_shake": true
    },
    "loot": {
      "types": ["weapon", "armor", "ring", "potion_health", "potion_mana", "gold"],
      "rarity": ["common", "uncommon", "rare", "epic"]
    },
    "ui": {
      "type": "html_css_overlay",
      "elements": ["health_bar", "mana_bar", "xp_bar", "minimap", "inventory", "loot_popup", "damage_numbers"]
    },
    "audio": {
      "sfx": ["attack_swing", "hit_enemy", "hit_player", "enemy_die", "pickup_item", "level_up", "potion_use", "door_open"],
      "music": ["dungeon_ambient", "boss_battle", "menu_theme"]
    },
    "lighting": {
      "ambient": "dim_blue",
      "player_light": "warm_point",
      "torch_lights": "flickering_orange",
      "fog": "exponential_dark"
    },
    "effects": {
      "particles": ["blood_splatter", "magic_sparkle", "loot_glow", "torch_fire", "death_smoke"],
      "post_processing": ["bloom", "vignette"]
    }
  },
  "test_hooks": {
    "expose_on_window": true,
    "api": {
      "getPlayer": "returns {x, y, z, health, mana, level, xp, alive}",
      "getScore": "returns gold count",
      "getLives": "returns health value",
      "getEnemies": "returns [{x, y, z, type, hp, alive}]",
      "getCurrentScene": "returns scene state string",
      "getLevel": "returns dungeon floor number",
      "getInventory": "returns [{slot, item, stats}]"
    }
  },
  "assets_3d": {
    "format": "glb",
    "characters": "quaternius",
    "environments": "kenney_dungeon + quaternius_dungeons",
    "weapons": "quaternius_weapons"
  }
}
